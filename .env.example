# Root .env.example — copy to .env and fill in values
# Also copy backend/.env.example to backend/.env
# Also copy frontend/.env.local.example to frontend/.env.local

# ─── PostgreSQL ────────────────────────────────────────
POSTGRES_DB=sasklifehub
POSTGRES_USER=sasklifehub
POSTGRES_PASSWORD=change-me-in-production

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Flask Backend ─────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_SECRET_KEY=change-me-jwt-secret-key
DATABASE_URL=postgresql://sasklifehub:change-me@localhost:5432/sasklifehub

# ─── Email (SMTP) ───────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@sasklifehub.com

# ─── Next.js Frontend ──────────────────────────────────
NEXT_PUBLIC_AUTH_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
