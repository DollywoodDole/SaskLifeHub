# Copy this file to .env and fill in your values.
#
# Development: set this to your machine's LAN IP address so that the
#   Android/iOS device or emulator can reach the Flask server running on
#   your computer.  Do NOT use "localhost" — it resolves to the device itself,
#   not your host machine.
#   Example: http://192.168.1.42:5000
#
# Production: set this to your Railway (or other cloud host) URL.
#   Example: https://sasklifehub-backend.up.railway.app

EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:5000
